{
  "id": "com.duckmotion.transcription",
  "name": "Duckmotion Transcription",
  "version": "1.0.0",
  "main": "index.html",
  "manifestVersion": 5,
  "host": {
    "app": "premierepro",
    "minVersion": "25.0"
  },
  "requiredPermissions": {
    "network": {
      "domains": ["https://backend-duckcaption.onrender.com"]
    },
    "localFileSystem": "fullAccess",
    "launchProcess": {
      "schemes": ["file", "http", "https"],
      "extensions": ["wav", "mp3", "mp4", "mov"]
    }
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "transcriptionPanel",
      "label": {
        "default": "Duckmotion"
      }
    }
  ]
}